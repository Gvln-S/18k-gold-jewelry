---
import FeaturedProducts from "../../layouts/components/FeaturedProducts.astro";
import config from "../../config/config.json";
import Base from "../../layouts/Base.astro";
import { getProduct, getProducts, getProductRecommendations } from "../../lib/shopify";

// Importaciones con rutas relativas para evitar el error de "client:only"
import ProductGallery from "../../layouts/functional-components/product/ProductGallery";
import ShowTags from "../../layouts/functional-components/product/ShowTags";
import Tabs from "../../layouts/functional-components/product/Tabs";
import { VariantSelector } from "../../layouts/functional-components/product/VariantSelector";
import SocialShare from "../../layouts/functional-components/SocialShare";

// Función obligatoria para generar las páginas en modo estático
export async function getStaticPaths() {
  const { products } = await getProducts();
  return products.map((product) => ({
    params: { slug: product.handle },
  }));
}

const { slug } = Astro.params;
const product = await getProduct(slug as string);

if (!product) {
  return Astro.redirect("/404");
}

const {
  id,
  title,
  description,
  descriptionHtml,
  priceRange,
  compareAtPriceRange,
  images,
  options,
  variants,
  tags,
} = product;

const relatedProducts = await getProductRecommendations(id);
const { currencySymbol } = config.shopify;
---

<Base title={title}>
  <section class="md:section-sm">
    <div class="container">
      <div class="row justify-center">
        {/* Galería de imágenes */}
        <div class="col-10 md:col-8 lg:col-6">
          <ProductGallery client:only="react" images={images} />
        </div>

        {/* Detalles del producto */}
        <div class="col-10 md:col-8 lg:col-5 md:ml-7 py-6 lg:py-0">
          <h1 class="text-3xl md:h2 mb-2 md:mb-6">{title}</h1>

          <div class="flex gap-2 items-center">
            <h4 class="text-text-light dark:text-darkmode-text-light max-md:h2">
              {currencySymbol}
              {priceRange?.minVariantPrice.amount}{" "}
              {priceRange?.minVariantPrice?.currencyCode}
            </h4>
            {
              compareAtPriceRange?.maxVariantPrice &&
              parseFloat(compareAtPriceRange.maxVariantPrice.amount) > 0 && (
                <s class="text-text-light max-md:h3 dark:text-darkmode-text-light">
                  {currencySymbol}{" "}
                  {compareAtPriceRange.maxVariantPrice.amount}{" "}
                  {compareAtPriceRange.maxVariantPrice.currencyCode}
                </s>
              )
            }
          </div>

          <div class="my-10 space-y-6">
            {
              options && (
                <VariantSelector
                  client:only="react"
                  options={options}
                  variants={variants}
                  images={images}
                />
              )
            }
          </div>

          <hr class="my-6 border border-border dark:border-border/40" />

          {/* Compartir */}
          <div class="flex gap-3 items-center mb-6">
            <h5 class="max-md:text-base text-white">Share:</h5>
            <SocialShare
              socialName={title}
              className="social-share flex gap-2"
              pathname={Astro.url.pathname}
              client:only="react"
            />
          </div>

          {/* Etiquetas */}
          {
            tags.length > 0 && (
              <div class="flex flex-wrap gap-3 items-center">
                <h5 class="max-md:text-base text-white">Tags:</h5>
                <ShowTags client:only="react" tags={tags} />
              </div>
            )
          }
        </div>
      </div>
    </div>
  </section>

  {/* Pestañas de descripción */}
  {
    descriptionHtml && (
      <section>
        <div class="container">
          <div class="row">
            <div class="col-10 lg:col-11 mx-auto mt-12">
              <Tabs client:only="react" descriptionHtml={descriptionHtml} />
            </div>
          </div>
        </div>
      </section>
    )
  }

  {/* Productos Relacionados */}
  {
    relatedProducts && relatedProducts.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="text-center mb-6 md:mb-14">
            <h2 class="mb-2">Related Products</h2>
          </div>
          <FeaturedProducts products={relatedProducts.slice(0, 4)} />
        </div>
      </section>
    )
  }
</Base>
